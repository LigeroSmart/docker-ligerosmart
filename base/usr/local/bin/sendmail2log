#!/bin/sh
# Redirect sendmail output to container stdout
ts="$(date)"
to=""
subject=""

while IFS= read -r line; do
  [ "$line" = "" ] && break
  case "$line" in
    To:*) to="${line#To: }" ;;
    Subject:*) subject="${line#Subject: }" ;;
  esac
done

printf "%s [sendmail] To=%s Subject=%s\n" "$ts" "${to:-unknown}" "${subject:-none}"
cat
exit 0
