#!/bin/sh
# Redirect sendmail output to container stdout
out="/proc/1/fd/1"
ts="$(date)"
to=""
subject=""

while IFS= read -r line; do
  [ "$line" = "" ] && break
  case "$line" in
    To:*) to="${line#To: }" ;;
    Subject:*) subject="${line#Subject: }" ;;
  esac
done

printf "%s [sendmail] To=%s Subject=%s\n" "$ts" "${to:-unknown}" "${subject:-none}" >> "$out" 2>&1
cat >> "$out" 2>&1
printf "\n----- end mail output -----\n\n" >> "$out" 2>&1
exit 0
